
QWidget {
    background-color: $base_bg;
    color: $text;
    font-size: 13px;
}

QMainWindow, QFrame {
    background-color: $base_bg;
}

QSplitter::handle {
    background-color: $border;
    width: 5px;
}
QSplitter::handle:hover {
    background-color: $accent;
}

QLineEdit {
    background-color: $surface;
    color: $text;
    border: 1px solid $border;
    border-radius: 4px;
    padding: 2px 6px;
    selection-background-color: $accent;
    selection-color: $base;
}

QLineEdit:focus {
    border-color: $accent;
}

QTableView {
    background-color: transparent;
    color: $text;
    border: none;
    outline: 0;
    selection-background-color: $selection_bg;
    selection-color: $base;
}

QHeaderView::section {
    background-color: $surface2;
    color: $text_dim;
    border: none;
    border-bottom: 1px solid $border;
    padding: 2px 6px;
    font-size: 11px;
}

QPushButton {
    background-color: $surface2;
    color: $text;
    border: 1px solid $border;
    border-radius: 3px;
    padding: 2px 8px;
}

QPushButton:hover {
    background-color: $accent;
    color: $base;
    border-color: $accent;
}

QPushButton:pressed {
    background-color: $accent2;
}

ActionBar QPushButton {
    min-width: 0;
    padding: 4px 6px;
    font-size: 12px;
}

QTabBar {
    background-color: $surface;
}

QTabBar::tab {
    background-color: $surface;
    color: $text_dim;
    padding: 4px 12px;
    border: none;
    border-bottom: 2px solid transparent;
}

QTabBar::tab:selected {
    color: $text;
    border-bottom: 2px solid $accent;
}

QTabBar::tab:hover {
    background-color: $surface2;
}

QTabBar::close-button {
    subcontrol-position: right;
}
QTabBar::close-button:hover {
    background-color: $red;
    border-radius: 2px;
}

QMenu {
    background-color: $surface_opaque;
    color: $text;
    border: 1px solid $border;
    border-radius: 6px;
    padding: 4px 0;
}

QMenu::item {
    padding: 4px 20px;
}

QMenu::item:selected {
    background-color: $accent;
    color: $base;
}

QMenu::separator {
    height: 1px;
    background-color: $border;
    margin: 2px 0;
}

QMenuBar {
    background-color: $surface;
    color: $text;
    border: none;
}

QMenuBar::item {
    background-color: transparent;
    padding: 2px 8px;
}

QMenuBar::item:selected {
    background-color: $surface2;
}

QStatusBar {
    max-height: 0;
    padding: 0;
    border: none;
    background: transparent;
}

QLabel {
    color: $text_dim;
    background-color: transparent;
}

QTextBrowser {
    background-color: transparent;
    border: none;
}

QScrollArea {
    background-color: transparent;
    border: none;
}

QAbstractScrollArea > QWidget {
    background-color: transparent;
}

QScrollBar:vertical {
    background-color: $surface;
    width: 8px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: $border;
    border-radius: 4px;
    min-height: 20px;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QListWidget {
    background-color: $surface;
    color: $text;
    border: none;
    outline: none;
}

QListWidget::item:selected {
    background-color: $selection_bg;
    color: $base;
}

QListWidget::item:hover {
    background-color: $surface2;
}

QFrame#command-palette {
    background-color: $surface;
    border: 1px solid $accent;
    border-radius: 6px;
}

PaneSideView[active="true"] {
    border-left: 3px solid $accent;
    border-top: 1px solid $accent;
    border-right: none;
    border-bottom: none;
}
PaneSideView[active="false"] {
    border-left: 3px solid transparent;
    border-top: 1px solid transparent;
    border-right: none;
    border-bottom: none;
}
PaneSideView[active="false"] QTableView {
    selection-background-color: $surface2;
    selection-color: $text_dim;
}
PaneSideView[active="false"] QTabBar::tab:selected {
    border-bottom-color: $border;
}

/* Confirm dialog */
QPushButton#danger {
    background-color: $red;
    color: $base_bg;
    border-color: $red;
}
QPushButton#danger:hover {
    background-color: $accent2;
    border-color: $accent2;
}

/* Breadcrumb bar */
QToolButton[crumb="true"] {
    background: transparent;
    border: none;
    padding: 1px 4px;
    color: $text_dim;
}
QToolButton[crumb_active="true"] {
    color: $text;
    font-weight: bold;
}
QToolButton[crumb="true"]:hover {
    text-decoration: underline;
}
QLabel#crumb_sep {
    color: $text_dim;
    padding: 0 2px;
}
